rec {
  path = "@testPath@";
  nixBinDir = "@nixBinDir@";
  bash = "@bash@";

  mkDerivation = args:
    derivation ({
      system = builtins.currentSystem;
      PATH = path;
    } // args);
  mkContentAddressedDerivation = args: mkDerivation ({
    __contentAddressed = true;
    outputHashMode = "recursive";
    outputHashAlgo = "sha256";
  } // args);
}
